# DeepResearchAgent — Environment Variables
# Copy this file to .env and fill in real values.

# ─── Required ─────────────────────────────────────────────────────────────────

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Tavily search API key (https://app.tavily.com)
TAVILY_API_KEY=tvly-...

# ─── Optional runtime tokens ──────────────────────────────────────────────────

# Telegram bot token (from @BotFather) — only needed for Telegram runtime
# TELEGRAM_BOT_TOKEN=...

# ─── Optional: Research Tuning ────────────────────────────────────────────────

# Max parallel researcher sub-agents per supervisor iteration (default: 1)
# MAX_CONCURRENT_RESEARCHERS=1

# Max supervisor iterations before stopping (default: 5)
# MAX_RESEARCHER_ITERATIONS=5

# ─── Optional: Model Overrides ────────────────────────────────────────────────

# BASE_MODEL=openai:gpt-4o
# CREATIVE_MODEL=openai:gpt-4o
# WRITER_MODEL=openai:gpt-5
# COMPRESS_MODEL=openai:gpt-4o
# COMPRESSOR_MODEL=openai:gpt-4o-mini
# SUMMARIZATION_MODEL=openai:gpt-4o-mini
# CRITIC_MODEL=openai:gpt-4o
# JUDGE_MODEL=openai:gpt-4o

# ─── Optional: Timeouts ───────────────────────────────────────────────────────

# Max seconds for a full research request (default: 600 = 10 min)
# REQUEST_TIMEOUT_SECONDS=600

# Max seconds per researcher sub-agent invocation (default: 120)
# RESEARCHER_TIMEOUT_SECONDS=120

# ─── Optional: LangSmith Observability ───────────────────────────────────────
# Sign up at https://smith.langchain.com, get an API key, then set these.
# Traces will appear automatically in your LangSmith project dashboard.

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=deepresearch-prod

# ─── Optional: Logging ────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Path to write rotating log file (10 MB limit, 5 backups kept).
# If not set, logs only go to stdout (terminal).
# LOG_FILE=logs/app.log
